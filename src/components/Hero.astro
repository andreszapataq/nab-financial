---
/**
 * Hero — staggered left column (eyebrow, headline with highlighted word, body,
 * CTAs, rating) and a right photo frame with two floating trust cards.
 */
import { Icon } from 'astro-icon/components';
import Button from './ds/Button.astro';
import ImageFrame from './ImageFrame.astro';
import { STR, DEFAULT_LANG } from '../i18n/strings';

const t = STR[DEFAULT_LANG];
---

<section class="hero">
  <div class="container hero__grid nab-2col">
    <div data-stagger>
      <span class="nab-eyebrow" data-reveal>
        <span class="nab-chevron"></span><span data-i18n="heroEyebrow">{t.heroEyebrow}</span>
      </span>
      <h1 class="hero__title" data-reveal>
        <span data-i18n="heroTitleA">{t.heroTitleA}</span><span class="hero__hi" data-i18n="heroTitleHi">{t.heroTitleHi}</span>
      </h1>
      <p class="hero__body" data-reveal data-i18n="heroBody">{t.heroBody}</p>
      <div class="hero__ctas" data-reveal>
        <Button size="lg" iconRight="calendar" data-open-modal>
          <span data-i18n="ctaBook">{t.ctaBook}</span>
        </Button>
        <Button size="lg" variant="outline" href="#servicios">
          <span data-i18n="ctaView">{t.ctaView}</span>
        </Button>
      </div>
      <div class="hero__rating" data-reveal>
        <span class="hero__stars" aria-hidden="true">
          {Array.from({ length: 5 }).map(() => <Icon name="star-solid" width={18} height={18} class="star" />)}
        </span>
        <span class="hero__rating-text">
          <b>5,000+</b> <span data-i18n="heroRating">{t.heroRating}</span>
        </span>
      </div>
    </div>

    <div class="hero__media" data-reveal="right">
      <ImageFrame
        height={460}
        radius={24}
        parallax={0.06}
        src="/assets/hero.jpg"
        srcset="/assets/hero.jpg 1x, /assets/hero@2x.jpg 2x"
        alt="Equipo de NAB Financial Consulting atendiendo a clientes en la oficina"
        objectPosition="78% center"
      />
      <div class="hero__card">
        <span class="hero__card-icon" aria-hidden="true">
          <Icon name="lucide:shield-check" width={22} height={22} />
        </span>
        <div>
          <div class="hero__card-a" data-i18n="heroCardA">{t.heroCardA}</div>
          <div class="hero__card-b" data-i18n="heroCardB">{t.heroCardB}</div>
        </div>
      </div>
      <div class="hero__pill">
        <span class="hero__dot" aria-hidden="true"></span>
        <span data-i18n="heroChip">{t.heroChip}</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: radial-gradient(1100px 520px at 80% -10%, var(--surface-brand-subtle), transparent 60%),
      var(--surface-page);
  }
  .hero__grid {
    display: grid;
    grid-template-columns: 1.08fr 0.92fr;
    gap: var(--space-10);
    align-items: center;
    padding-top: var(--space-12);
    padding-bottom: var(--space-11);
  }
  .hero__title {
    font-size: clamp(2.6rem, 4.4vw, 4rem);
    font-weight: var(--weight-extra);
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-top: 18px;
  }
  .hero__hi {
    color: var(--text-brand);
  }
  .hero__body {
    margin-top: var(--space-5);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
    max-width: 52ch;
  }
  .hero__ctas {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-7);
    flex-wrap: wrap;
  }
  .hero__rating {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }
  .hero__stars {
    display: flex;
    gap: 2px;
  }
  .hero__stars :global(.star) {
    color: #e8a317;
    fill: #e8a317;
  }
  .hero__rating-text {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-weight: 600;
  }
  .hero__rating-text b {
    color: var(--text-primary);
  }

  .hero__media {
    position: relative;
  }
  .hero__card {
    position: absolute;
    left: -22px;
    bottom: 34px;
    background: #fff;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    padding: 16px 18px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .hero__card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: var(--surface-brand-subtle);
    color: var(--color-brand-strong);
  }
  .hero__card-a {
    font-weight: 800;
    font-size: var(--text-base);
  }
  .hero__card-b {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }
  .hero__pill {
    position: absolute;
    right: -14px;
    top: 28px;
    background: var(--surface-inverse);
    color: #fff;
    border-radius: var(--radius-pill);
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    box-shadow: var(--shadow-lg);
    font-weight: 700;
    font-size: var(--text-sm);
  }
  .hero__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-brand);
  }

  @media (max-width: 640px) {
    .hero__card {
      left: 8px;
    }
    .hero__pill {
      right: 8px;
    }
  }
</style>
