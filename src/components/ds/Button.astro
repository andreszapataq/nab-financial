---
/**
 * Design-system Button.
 * Variants: primary (default) · outline · secondary (dark) · ghost.
 * Sizes: sm · md (default) · lg. Full pill radius; primary carries a green glow.
 * Renders an <a> when `href` is set, otherwise a <button>.
 */
import { Icon } from 'astro-icon/components';

interface Props {
  variant?: 'primary' | 'outline' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit';
  iconLeft?: string;
  iconRight?: string;
  fullWidth?: boolean;
  class?: string;
  [key: string]: unknown;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  iconLeft,
  iconRight,
  fullWidth = false,
  class: extraClass = '',
  ...rest
} = Astro.props;

const Tag = href ? 'a' : 'button';
const iconSize = size === 'lg' ? 20 : 16;
const classes = [
  'ds-btn',
  `ds-btn--${variant}`,
  `ds-btn--${size}`,
  fullWidth ? 'ds-btn--full' : '',
  extraClass,
]
  .filter(Boolean)
  .join(' ');
---

<Tag
  class={classes}
  href={href}
  type={href ? undefined : type}
  {...rest}
>
  {iconLeft && <Icon name={`lucide:${iconLeft}`} width={iconSize} height={iconSize} aria-hidden="true" />}
  <span><slot /></span>
  {iconRight && <Icon name={`lucide:${iconRight}`} width={iconSize} height={iconSize} aria-hidden="true" />}
</Tag>

<style>
  .ds-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-family: var(--font-sans);
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
    border: 1.5px solid transparent;
    border-radius: var(--radius-pill);
    cursor: pointer;
    text-decoration: none;
    transition: background var(--duration-base) var(--ease-out),
      color var(--duration-base) var(--ease-out),
      border-color var(--duration-base) var(--ease-out),
      box-shadow var(--duration-base) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .ds-btn:active {
    transform: translateY(1px) scale(0.985);
  }

  .ds-btn--full {
    width: 100%;
  }

  /* Sizes */
  .ds-btn--sm {
    height: 38px;
    padding: 0 16px;
    font-size: var(--text-sm);
  }
  .ds-btn--md {
    height: 46px;
    padding: 0 20px;
    font-size: var(--text-base);
  }
  .ds-btn--lg {
    height: 56px;
    padding: 0 26px;
    font-size: var(--text-md);
  }

  /* Variants */
  .ds-btn--primary {
    background: var(--color-brand);
    color: var(--text-on-brand);
    box-shadow: var(--shadow-brand);
  }
  .ds-btn--primary:hover {
    background: var(--color-brand-strong);
  }

  .ds-btn--outline {
    background: transparent;
    color: var(--text-brand);
    border-color: var(--border-default);
  }
  .ds-btn--outline:hover {
    border-color: var(--color-brand);
    background: var(--surface-brand-subtle);
  }

  .ds-btn--secondary {
    background: var(--surface-inverse);
    color: #fff;
  }
  .ds-btn--secondary:hover {
    background: #1f2422;
  }

  .ds-btn--ghost {
    background: transparent;
    color: #fff;
    border-color: rgba(255, 255, 255, 0.55);
  }
  .ds-btn--ghost:hover {
    background: rgba(255, 255, 255, 0.12);
  }
</style>
