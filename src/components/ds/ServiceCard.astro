---
/**
 * Design-system ServiceCard.
 * White card, tinted 56px icon chip (brand green or teal accent), title,
 * description and a "Learn more →" affordance whose arrow nudges on hover.
 * The whole card is a button that opens the contact modal.
 */
import { Icon } from 'astro-icon/components';

interface Props {
  icon: string;
  title: string;
  description: string;
  accent?: 'brand' | 'accent';
  linkLabel: string;
  index: number;
}

const { icon, title, description, accent = 'brand', linkLabel, index } = Astro.props;
---

<button
  type="button"
  class={`svc-card svc-card--${accent}`}
  data-open-modal
  aria-label={title}
>
  <span class="svc-card__chip" aria-hidden="true">
    <Icon name={`lucide:${icon}`} width={26} height={26} />
  </span>
  <h3 class="svc-card__title" data-i18n={`services.${index}.title`}>{title}</h3>
  <p class="svc-card__desc" data-i18n={`services.${index}.desc`}>{description}</p>
  <span class="svc-card__link">
    <span data-i18n="ctaMore">{linkLabel}</span>
    <Icon class="svc-card__arrow" name="lucide:arrow-right" width={16} height={16} aria-hidden="true" />
  </span>
</button>

<style>
  .svc-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 14px;
    width: 100%;
    height: 100%;
    text-align: left;
    background: var(--surface-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    padding: var(--space-7);
    cursor: pointer;
    font-family: var(--font-sans);
    transition: transform var(--duration-base) var(--ease-out),
      box-shadow var(--duration-base) var(--ease-out),
      border-color var(--duration-base) var(--ease-out);
  }

  .svc-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-xl);
    border-color: var(--color-brand);
  }

  .svc-card__chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-md);
  }

  .svc-card--brand .svc-card__chip {
    background: var(--surface-brand-subtle);
    color: var(--color-brand-strong);
  }
  .svc-card--accent .svc-card__chip {
    background: var(--surface-accent-subtle);
    color: var(--teal-600);
  }

  .svc-card__title {
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .svc-card__desc {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
  }

  .svc-card__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: auto;
    padding-top: 4px;
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--text-brand);
  }

  .svc-card__arrow {
    transition: transform var(--duration-base) var(--ease-out);
  }
  .svc-card:hover .svc-card__arrow {
    transform: translateX(4px);
  }
</style>
