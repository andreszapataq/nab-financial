---
/**
 * Rounded, overflow-hidden photo frame with a parallax inner layer.
 *
 * The inner layer is ~44px taller than the frame and offset `top:-44px` so the
 * parallax shift never exposes a gap (per the design spec). When `src` is set it
 * renders a responsive <img>; otherwise it renders a branded placeholder so the
 * layout is complete before the client supplies real photography.
 *
 * To wire real photos: drop the image in /public/assets and pass
 *   <ImageFrame src="/assets/hero.jpg" srcset="/assets/hero.jpg 1x, /assets/hero@2x.jpg 2x" ... />
 */
import { Icon } from 'astro-icon/components';

interface Props {
  height: number;
  radius: number;
  parallax: number;
  alt?: string;
  src?: string;
  srcset?: string;
  placeholder?: string;
  hint?: string;
}

const {
  height,
  radius,
  parallax,
  alt = '',
  src,
  srcset,
  placeholder = 'Foto',
  hint,
} = Astro.props;
const innerHeight = height + 88;
---

<div class="frame" style={`height:${height}px;border-radius:${radius}px;`}>
  <div class="frame__inner" data-parallax={parallax} style={`height:${innerHeight}px;`}>
    {
      src ? (
        <img src={src} srcset={srcset} alt={alt} loading="lazy" decoding="async" />
      ) : (
        <div class="frame__placeholder">
          <Icon name="lucide:image" width={30} height={30} aria-hidden="true" />
          <span>{hint ?? placeholder}</span>
        </div>
      )
    }
  </div>
</div>

<style>
  .frame {
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }
  .frame__inner {
    position: absolute;
    top: -44px;
    left: 0;
    width: 100%;
    display: block;
  }
  .frame__inner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .frame__placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    height: 100%;
    padding: 24px;
    text-align: center;
    color: var(--color-brand-strong);
    background: linear-gradient(150deg, var(--surface-brand-subtle) 0%, var(--surface-accent-subtle) 100%);
  }
  .frame__placeholder span {
    font-size: var(--text-sm);
    font-weight: 600;
    max-width: 24ch;
  }
</style>
