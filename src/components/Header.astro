---
/**
 * Sticky, blurred header — logo left; nav links, phone, ES/EN toggle and the
 * primary "Book appointment" CTA clustered right.
 */
import { Icon } from 'astro-icon/components';
import Button from './ds/Button.astro';
import { STR, DEFAULT_LANG } from '../i18n/strings';

const t = STR[DEFAULT_LANG];
---

<header id="top" class="site-header">
  <div class="container site-header__bar">
    <a href="#top" class="site-header__logo" aria-label="NAB Financial Consulting">
      <img src="/assets/nab-logo-cropped.svg" alt="NAB Financial Consulting" height="52" />
    </a>
    <div class="site-header__right">
      <nav class="nab-desktop-nav" aria-label="Primary">
        <a href="#servicios" data-i18n="navServices">{t.navServices}</a>
        <a href="#nosotros" data-i18n="navAbout">{t.navAbout}</a>
        <a href="#opiniones" data-i18n="navReviews">{t.navReviews}</a>
        <a href="#preguntas" data-i18n="navFaq">{t.navFaq}</a>
        <a href="tel:+18328010188" class="site-header__phone">
          <Icon name="lucide:phone" width={18} height={18} aria-hidden="true" />(832) 801-0188
        </a>
      </nav>
      <div class="lang-toggle" role="group" aria-label="Language">
        <button type="button" class="lang-toggle__btn is-active" data-lang="es">ES</button>
        <button type="button" class="lang-toggle__btn" data-lang="en">EN</button>
      </div>
      <Button size="sm" iconRight="calendar" data-open-modal>
        <span data-i18n="ctaBook">{t.ctaBook}</span>
      </Button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.86);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-subtle);
  }
  .site-header__bar {
    height: 80px;
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }
  .site-header__logo {
    display: flex;
    align-items: center;
  }
  .site-header__logo img {
    height: 52px;
    width: auto;
  }
  .site-header__right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }
  .nab-desktop-nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }
  .nab-desktop-nav > a {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--duration-base) var(--ease-out);
  }
  .nab-desktop-nav > a:hover {
    color: var(--text-primary);
  }
  .site-header__phone {
    color: var(--text-brand) !important;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
    flex: none;
  }
  .lang-toggle {
    display: inline-flex;
    padding: 3px;
    background: var(--surface-muted);
    border-radius: var(--radius-pill);
  }
  .lang-toggle__btn {
    border: none;
    cursor: pointer;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: var(--text-sm);
    letter-spacing: 0.02em;
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    background: transparent;
    color: var(--text-muted);
    transition: var(--transition-base);
  }
  .lang-toggle__btn.is-active {
    background: #fff;
    color: var(--text-brand);
    box-shadow: var(--shadow-xs);
  }
</style>
